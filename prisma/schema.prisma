  EXAGGERATED_CLAIM
  EFFECT_PROMISE
  MEDICAL_RISK
  FINANCE_RISK
  MISSING_DISCLOSURE
}

enum SprintStatus {
  PLANNED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum StrategyTaskType {
