  VIDEO
  VOICE
  MUSIC
  PACKAGE
}

enum RenderProvider {
  COMFYUI
  RUNWAY
  KLING
  LUMA
  ELEVENLABS
  CUSTOM
}

enum RenderJobStatus {
  DRAFT
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum RenderAssetType {
  IMAGE
  VIDEO
  AUDIO
  SUBTITLE
  ARCHIVE
  PREVIEW
}

enum ProjectStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
  ARCHIVED
}

enum TaskType {
  TREND_RESEARCH
  CREATOR_DISCOVERY
  CONTENT_DISCOVERY
  SCRIPT_REWRITE
  SHOT_BREAKDOWN
  REPORT_GENERATION
}

enum TaskStatus {
