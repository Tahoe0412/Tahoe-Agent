  RESEARCH
  SCRIPT
  STORYBOARD
  ASSET_PLAN
  RENDER
  DELIVERY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

enum StoryboardStatus {
  DRAFT
  ACTIVE
  APPROVED
  ARCHIVED
}

enum FrameStatus {
  DRAFT
  READY
  LOCKED
  OMITTED
}

enum FrameReferenceType {
  STYLE
  CHARACTER
  PRODUCT
  ENVIRONMENT
  COMPOSITION
  PROP
  WARDROBE
}

enum ReviewTargetType {
  BRIEF
  SCRIPT
  SCENE
  STORYBOARD
  FRAME
  RENDER_JOB
  REPORT
}

enum ReviewSeverity {
