generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Platform {
  YOUTUBE
  X
  TIKTOK
  XHS
  DOUYIN
}

enum LlmProvider {
  OPENAI
  GEMINI
  DEEPSEEK
  QWEN
}

enum SearchProvider {
  MOCK
  TAVILY
}

enum BrandStage {
  COLD_START
  VALIDATION
  SCALE
}

enum IndustryResearchStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CompetitorTier {
  DIRECT
  ASPIRATIONAL
  CATEGORY_LEADER
}

enum ContentPillarType {
  EDUCATION
  BRAND_STORY
  PRODUCT_VALUE
  USE_CASE
  TRUST_SIGNAL
  FOUNDER_IP
  USER_TESTIMONIAL
  TREND_REACTION
}

enum PlatformSurface {
  XIAOHONGSHU_POST
  XIAOHONGSHU_VIDEO
  DOUYIN_VIDEO
  DOUYIN_TITLE
  COMMENT_REPLY
  COVER_COPY
}

enum AdaptationStatus {
  DRAFT
  READY
  APPROVED
  ARCHIVED
}

enum ComplianceCheckStatus {
  PENDING
  PASSED
  NEEDS_REVIEW
  BLOCKED
}

enum ComplianceIssueType {
