DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_video_mvp?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ai_video_mvp?schema=public"
NEXT_PUBLIC_APP_NAME="AI Video Research Orchestrator"
OPENAI_API_KEY=""
GEMINI_API_KEY=""
DEEPSEEK_API_KEY=""
QWEN_API_KEY=""
# Optional: use a local OpenAI-compatible Qwen server instead of DashScope.
# Accepts either a root URL (http://127.0.0.1:1234), a /v1 URL, or a full /v1/chat/completions URL.
QWEN_BASE_URL=""
# 本地开发建议把真实 key 写进 .env.local，这样即使重置数据库，设置页也会自动带出这些默认值
OPENAI_MODEL="gpt-5.4-mini"
LLM_PROVIDER="OPENAI"
LLM_MOCK_MODE="true"
LLM_ROUTE_MARKETING_ANALYSIS_PROVIDER="OPENAI"
LLM_ROUTE_MARKETING_ANALYSIS_MODEL="gpt-5.4"
LLM_ROUTE_PROMOTIONAL_COPY_PROVIDER="QWEN"
LLM_ROUTE_PROMOTIONAL_COPY_MODEL="qwen3-max"
LLM_ROUTE_PLATFORM_ADAPTATION_PROVIDER="QWEN"
LLM_ROUTE_PLATFORM_ADAPTATION_MODEL="qwen3.5-plus"
LLM_ROUTE_SCRIPT_REWRITE_PROVIDER="GEMINI"
LLM_ROUTE_SCRIPT_REWRITE_MODEL="gemini-3.1-pro-preview"
LLM_ROUTE_SCENE_CLASSIFICATION_PROVIDER="OPENAI"
LLM_ROUTE_SCENE_CLASSIFICATION_MODEL="gpt-5.4-mini"
LLM_ROUTE_ASSET_ANALYSIS_PROVIDER="OPENAI"
LLM_ROUTE_ASSET_ANALYSIS_MODEL="gpt-5.4-mini"
LLM_ROUTE_REPORT_GENERATION_PROVIDER="OPENAI"
LLM_ROUTE_REPORT_GENERATION_MODEL="gpt-5.4"
NEWS_SEARCH_PROVIDER="MOCK"
NEWS_SEARCH_MOCK_MODE="true"
TAVILY_API_KEY=""
YOUTUBE_API_KEY=""
X_BEARER_TOKEN=""
TIKTOK_ACCESS_TOKEN=""
APP_BASE_URL="http://localhost:3000"
PREVIEW_ACCESS_ENABLED="false"
PREVIEW_ACCESS_PASSWORD=""
PLATFORM_CONNECTOR_MODE="mock"
PLATFORM_CONNECTOR_TIMEOUT_MS="8000"
UPLOAD_STORAGE_MODE="local"
UPLOAD_BASE_PATH="public/uploads"
MAX_UPLOAD_MB="20"
# Vercel 上本地文件上传不持久，正式共享前建议切到对象存储
BLOB_READ_WRITE_TOKEN=""
